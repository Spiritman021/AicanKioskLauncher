<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AicanKioskLauncher" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/kiosk_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/kiosk_accent_secondary</item>
        <item name="android:windowBackground">@color/kiosk_background</item>
    </style>

    <style name="Theme.AicanKioskLauncher" parent="Base.Theme.AicanKioskLauncher" />

    <!-- Fullscreen Kiosk Theme — no status bar, no title -->
    <style name="Theme.AicanKioskLauncher.Kiosk">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@color/kiosk_background</item>
    </style>
</resources>