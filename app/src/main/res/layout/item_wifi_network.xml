<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/kiosk_surface"
    android:foreground="?attr/selectableItemBackground"
    android:minHeight="68dp"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp">

    <ImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/ic_wifi_24"
        android:tint="@color/kiosk_text_secondary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvWifiName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/kiosk_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWifiMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/kiosk_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ivWifiLock"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_gravity="center_vertical"
        android:layout_marginEnd="10dp"
        android:src="@android:drawable/ic_lock_lock"
        android:tint="@color/kiosk_text_secondary" />

    <ImageView
        android:id="@+id/ivWifiChevron"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/bg_wifi_icon_circle"
        android:padding="4dp"
        android:src="@drawable/ic_chevron_right_24"
        android:tint="@color/kiosk_text_secondary" />

</LinearLayout>
