<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kiosk_background">

    <TextView
        android:id="@+id/tvBatteryStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:background="@color/kiosk_surface"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        android:text="@string/battery_status_loading"
        android:textColor="@color/kiosk_text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Main content (scrollable) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Status Indicator -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.15"
            android:text="@string/kiosk_mode_active"
            android:textColor="@color/kiosk_status_active"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <!-- Digital Clock -->
            <TextView
                android:id="@+id/tvClock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.05"
                android:text="00:00:00 AM"
                android:gravity="center"
                android:textColor="@color/kiosk_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- No apps message (shown when whitelist is empty) -->
        <TextView
            android:id="@+id/tvNoApps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_whitelisted_apps"
            android:textColor="@color/kiosk_text_secondary"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Whitelisted Apps Grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvWhitelistedApps"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="60dp" />

    </LinearLayout>

    <!-- Status Detail -->
    <TextView
        android:id="@+id/tvStatusDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/kiosk_status_locked"
        android:textColor="@color/kiosk_text_secondary"
        android:layout_marginBottom="44dp"
        android:layout_gravity="bottom|center_horizontal"
        android:textSize="13sp" />

    <!-- Bottom Branding -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:alpha="0.6"
        android:text="@string/powered_by"
        android:textColor="@color/kiosk_text_secondary"
        android:textSize="12sp" />

</FrameLayout>
