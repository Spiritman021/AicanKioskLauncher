<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kiosk_background">

    <!-- Center content -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- App Logo (tappable for secret exit) -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:contentDescription="Aican Logo"
            android:src="@mipmap/ic_launcher"
            android:layout_marginBottom="32dp" />

        <!-- Digital Clock -->
        <TextView
            android:id="@+id/tvClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="00:00:00 AM"
            android:textColor="@color/kiosk_text_primary"
            android:textSize="48sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="24dp" />

        <!-- Status Indicator -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/kiosk_mode_active"
            android:textColor="@color/kiosk_status_active"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <!-- Status Detail -->
        <TextView
            android:id="@+id/tvStatusDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/kiosk_status_locked"
            android:textColor="@color/kiosk_text_secondary"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Bottom Branding -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:text="@string/powered_by"
        android:textColor="@color/kiosk_text_secondary"
        android:textSize="12sp"
        android:alpha="0.6" />

</FrameLayout>