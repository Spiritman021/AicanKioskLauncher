<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kiosk_background"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/update_title"
                android:textColor="@color/kiosk_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUpdateStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@color/kiosk_surface"
                android:padding="16dp"
                android:text="@string/update_status_loading"
                android:textColor="@color/kiosk_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/update_app_name"
                android:textColor="@color/kiosk_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvUpdateAppName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="@color/kiosk_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/update_company"
                android:textColor="@color/kiosk_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvUpdateCompany"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="@color/kiosk_text_primary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/update_current_version"
                android:textColor="@color/kiosk_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvInstalledVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="@color/kiosk_text_primary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/update_remote_version"
                android:textColor="@color/kiosk_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvRemoteVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="@color/kiosk_text_primary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/update_release_date"
                android:textColor="@color/kiosk_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvReleaseDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="@color/kiosk_text_primary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/update_apk_size"
                android:textColor="@color/kiosk_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvApkSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="@color/kiosk_text_primary"
                android:textSize="16sp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomActionBarUpdate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/kiosk_background"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRefreshUpdate"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="0.34"
                android:backgroundTint="@color/admin_button_bg"
                android:text="@string/update_button_refresh"
                android:textAllCaps="false"
                android:textColor="@color/admin_button_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnUpdateNow"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="0.66"
                android:enabled="false"
                android:text="@string/update_button_checking"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:backgroundTint="@color/kiosk_accent"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
